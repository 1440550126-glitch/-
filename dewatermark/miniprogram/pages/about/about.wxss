.profile { display: flex; align-items: center; }
.logo {
  width: 96rpx; height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3b6cff, #5b8cff);
  color: #fff;
  font-size: 44rpx;
  font-weight: 800;
  display: flex; align-items: center; justify-content: center;
}
.p-meta { margin-left: 24rpx; }
.p-name { font-size: 34rpx; font-weight: 700; }

.credits { margin-left: auto; text-align: center; }
.credits-num { font-size: 44rpx; font-weight: 800; color: var(--brand); }
.credits-lbl { font-size: 22rpx; color: var(--muted); margin-top: 2rpx; }

.share-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 28rpx 32rpx;
  text-align: left;
  background: linear-gradient(135deg, #eef3ff, #f6f9ff);
  border-radius: 24rpx;
}
.share-card::after { border: none; }
.share-t { font-size: 30rpx; font-weight: 700; }
.share-s { font-size: 23rpx; margin-top: 8rpx; }
.share-go { flex: none; color: var(--brand); font-size: 27rpx; font-weight: 600; }
.invited { margin-top: 10rpx; font-size: 23rpx; color: var(--brand); }

.menu { margin-top: 24rpx; padding: 0 32rpx; }
.mi {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  border-bottom: 1rpx solid var(--line);
  font-size: 30rpx;
  background: transparent;
}
.mi.no-line, .mi:last-child { border-bottom: none; }
.mi-btn { width: 100%; padding: 0; line-height: normal; text-align: left; }
.mi-btn::after { border: none; }
.arrow { color: #c4c9d4; font-size: 44rpx; }

.footnote { margin: 40rpx 12rpx; font-size: 22rpx; line-height: 1.6; }
