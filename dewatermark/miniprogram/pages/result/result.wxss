.player {
  width: 100%;
  height: 420rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #000;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 24rpx;
}
.grid-img {
  width: calc((100% - 20rpx) / 3);
  height: 220rpx;
  border-radius: 12rpx;
  background: #eef0f5;
}

.title {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 24rpx;
  gap: 16rpx;
}
.title-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: #3a4150;
}
.copy {
  flex: none;
  font-size: 26rpx;
  color: var(--brand);
}

.flex1 { flex: 1; }
.banner { margin-top: 24rpx; border-radius: 16rpx; overflow: hidden; }
.hint { font-size: 24rpx; }
.footnote { margin: 36rpx 12rpx; font-size: 22rpx; line-height: 1.6; }
