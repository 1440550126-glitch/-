.doc {
  height: 100vh;
  box-sizing: border-box;
  padding: 36rpx 36rpx 80rpx;
  background: #fff;
}
.doc-title { font-size: 40rpx; font-weight: 800; }
.doc-updated { font-size: 24rpx; margin-top: 10rpx; margin-bottom: 24rpx; }
.para { margin-top: 24rpx; }
.para-h { font-size: 30rpx; font-weight: 700; margin-bottom: 8rpx; }
.para-p { font-size: 27rpx; line-height: 1.75; color: #3a4150; }
