.hero {
  padding: 24rpx 8rpx 8rpx;
}
.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}
.hero-sub {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  line-height: 1.6;
}
.ph { color: #b7bcc7; }

.tag-warn {
  background: rgba(255, 138, 0, 0.12);
  color: #e07b00;
}
.link { font-size: 26rpx; }

.flex1 { flex: 1; }
.flex2 { flex: 2; }
.btn-ghost.flex1 { margin-right: 4rpx; }

.banner { margin-top: 24rpx; border-radius: 16rpx; overflow: hidden; }

.block-title { font-weight: 700; font-size: 30rpx; margin-bottom: 16rpx; }

.chips { display: flex; flex-wrap: wrap; gap: 16rpx; }
.chip {
  padding: 12rpx 28rpx;
  background: #f1f3f8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4a5160;
}

.steps { display: flex; flex-direction: column; gap: 18rpx; }
.step { display: flex; align-items: center; color: #4a5160; font-size: 27rpx; }
.step-n {
  flex: none;
  width: 40rpx; height: 40rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: var(--brand);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  line-height: 40rpx;
}

.footnote { margin: 36rpx 12rpx; font-size: 22rpx; line-height: 1.6; }
