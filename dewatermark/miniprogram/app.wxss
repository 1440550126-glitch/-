page {
  --brand: #3b6cff;
  --brand-d: #2a52d8;
  --ink: #1a1a1f;
  --muted: #8a909a;
  --line: #ececf0;
  --card: #ffffff;
  --bg: #f3f4f6;
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.wrap {
  padding: 28rpx;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(20, 24, 40, 0.05);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 46rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}
.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #3b6cff, #5b8cff);
  color: #fff;
}
.btn-primary[disabled] {
  background: #c8cfdd;
  color: #fff;
}

.btn-ghost {
  background: #f1f3f8;
  color: var(--ink);
}

.muted { color: var(--muted); }
.center { text-align: center; }
.row { display: flex; align-items: center; }
.spread { justify-content: space-between; }
.gap { gap: 16rpx; }
.mt { margin-top: 24rpx; }
.mt-s { margin-top: 12rpx; }
.tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(59, 108, 255, 0.1);
  color: var(--brand);
}
