# ===== 爆款工厂 · AI 电商带货视频（复制为 topview/.env，或配置仓库根 .env；全部可不配直接跑） =====

# 服务端口（默认 4499）
# TOPVIEW_PORT=4499

# 数据位置（默认 var/topview.sqlite 与 var/topview-uploads/）
# TOPVIEW_DB_PATH=var/topview.sqlite
# TOPVIEW_UPLOAD_DIR=var/topview-uploads

# ===== 火山方舟（Volcengine Ark）：留空 = 本地引擎模式，全流程零成本可体验 =====
# 控制台：https://console.volcengine.com/ark   文档：https://www.volcengine.com/docs/82379
# 注意：要在「API Key 管理」创建的 UUID 形态 Key；AKLT 开头的 AccessKey 不能用！
# Key 也可不写这里，启动后到「设置」页填写（存本机 SQLite，优先级高于环境变量）。
# ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型 ID（设置页可改；模型升级直接换 ID）
# ARK_MODEL_CHAT=doubao-seed-1-6-250615          # 脚本 / 翻译（OpenAI 兼容对话）
# ARK_MODEL_IMAGE=doubao-seedream-4-0-250828     # 文生图 / 商品图
# ARK_MODEL_VIDEO=doubao-seedance-1-0-pro-250528 # 图生视频 / 文生视频（异步任务）

# ===== OpenAI（可选）：把图像模型设为 gpt-image-1 即走 OpenAI 出图 =====
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
