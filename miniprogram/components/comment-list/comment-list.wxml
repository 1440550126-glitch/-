<view class="comments">
  <view class="title">评论 {{comments.length}}</view>
  <view wx:for="{{comments}}" wx:key="_id" class="comment">
    <image class="avatar" src="{{item.user.avatar}}" />
    <view class="body">
      <view class="name">{{item.user.nickname}} <text wx:if="{{item.user.is_ai_account}}" class="ai">AI</text></view>
      <view class="content">{{item.content}}</view>
      <view class="reply" catchtap="reply" data-id="{{item._id}}" data-name="{{item.user.nickname}}">回复 · 点一下文字会亮</view>
      <view wx:if="{{item.reply_to}}" class="reply-to">回复评论：{{item.reply_to}}</view>
    </view>
  </view>
  <view wx:if="{{!comments.length}}" class="empty">还没有评论，来点亮第一句回应。</view>
</view>
