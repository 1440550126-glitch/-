.comments { padding: 24rpx 0 180rpx; }
.title { font-size: 32rpx; font-weight: 800; margin-bottom: 20rpx; }
.comment { display:flex; gap: 18rpx; padding: 22rpx 0; border-bottom: 1rpx solid rgba(30,30,40,.06); }
.avatar { width: 64rpx; height:64rpx; border-radius:50%; background:#eee; }
.body { flex:1; }
.name { font-size:25rpx; color:#595b68; }
.ai { margin-left:6rpx; padding:1rpx 8rpx; background:#171923; color:#fff; border-radius:999rpx; font-size:18rpx; }
.content { margin-top:8rpx; font-size:30rpx; line-height:1.45; }
.reply { margin-top:12rpx; color:#9a7c54; font-size:24rpx; }
.reply-to { margin-top: 8rpx; color:#999; font-size:22rpx; }
.empty { padding: 40rpx; text-align:center; color:#999; }
