# ===== 灵境AI · 短剧创作工坊（复制为 lingjing/.env，或直接配置仓库根 .env，全部可不配直接跑） =====

# 服务端口（默认 4399）
# LINGJING_PORT=4399

# 数据位置（默认 var/lingjing.sqlite 与 var/lingjing-uploads/）
# LINGJING_DB_PATH=var/lingjing.sqlite
# LINGJING_UPLOAD_DIR=var/lingjing-uploads

# ===== 火山方舟（Volcengine Ark）：留空 = 本地引擎模式，全流程零成本可体验 =====
# 开通与文档：https://www.volcengine.com/docs/82379  控制台：https://console.volcengine.com/ark
# 注意：要在控制台「API Key 管理」创建的 Key（UUID 形态）；AKLT 开头的是 AccessKey，不能用！
# Key 也可以不写在这里，启动后到「设置」页填写（存本机 SQLite，优先级高于环境变量）
# ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型 ID（设置页可改；模型升级直接换 ID。2026 最新可选：图 Seedream 5.0、视频 Seedance 2.5，
#   到方舟控制台「开通管理」复制准确 ID 或推理接入点 ep-xxxx 后替换下面对应行）
# ARK_MODEL_CHAT=doubao-seed-1-6-250615          # 剧本/解析/Agent（需支持 function calling）
# ARK_MODEL_IMAGE=doubao-seedream-4-0-250828     # 文生图（角色/场景/分镜首帧）；最新 doubao-seedream-5-0（核对ID）
# ARK_MODEL_IMAGE_PRO=doubao-seedream-4-0-250828 # 角色身份板/全场景图用的最强图像模型
# ARK_MODEL_VIDEO=doubao-seedance-1-0-pro-250528 # 图生/文生视频；最新 doubao-seedance-2-5（30s/4K，核对ID）

# ===== 其它模型供应商（与火山方舟并存，可自由选用；各用各自独立 API Key）=====
# OpenAI GPT Image（图）：在「生成图片」里选 gpt-image-1，或把 ARK_MODEL_IMAGE 设为 gpt-image-1
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# Google Veo 3（视频）：在创作框视频模型里选 Veo 3（veo-3.0-generate-001）
# GOOGLE_API_KEY=xxxxxxxx
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# 阿里云百炼（DashScope）统一 Key：千问对话（model_chat 填 qwen-max/qwen-plus 等）+ 通义万相 图/视频
# DASHSCOPE_API_KEY=sk-xxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# Vidu 全能参考（多主体一致，国产多图参考最强）：视频选 Vidu Q1，配合「全能参考一键出片」
# VIDU_API_KEY=xxxxxxxx
# VIDU_BASE_URL=https://api.vidu.com
# 可灵 Kling（快手·国产视频第一梯队）：AK/SK 双密钥（JWT 鉴权）；视频选 kling-v2-x
# KLING_ACCESS_KEY=xxxxxxxx
# KLING_SECRET_KEY=xxxxxxxx
# KLING_BASE_URL=https://api-beijing.klingai.com
