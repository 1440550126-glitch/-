# ================= LingMirror AI 视频 · 环境变量（复制为 /opt/video/.env）=================
# 所有 API Key 仅放这里（环境变量），绝不写死在代码；留空则走本地占位引擎可先上线。

# ---- 运行（容器内，勿改；对外端口由 docker-compose 映射为 3002）----
LINGJING_PORT=4399
LINGJING_DB_PATH=/data/lingjing.sqlite
LINGJING_UPLOAD_DIR=/data/uploads

# ---- AI 模型供应商（按需填，可多家并存，自由切换）----
# 火山方舟（Seedream 文生图 / Seedance 文生·图生视频；UUID 形态 Key，非 AKLT）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OpenAI（GPT Image）
OPENAI_API_KEY=
# Google（Veo 3 文生/图生视频）
GOOGLE_API_KEY=
# 阿里云百炼 DashScope（千问对话 + 通义万相 图/视频，统一 Key）
DASHSCOPE_API_KEY=
# Vidu（全能参考·多主体一致视频）
VIDU_API_KEY=
# 火山语音 TTS（AI 配音）
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=

# ================= 以下为「预留接口」：账号互通(共用登录)，但钱包【不互通】(视频站独立) =================
# 主站 SSO（账号互通：登录走主站，PayPal/Google/GitHub/邮箱）—— 仅共享登录身份
LINGMIRROR_SSO_URL=https://api.lingmirror.com.cn
LINGMIRROR_SSO_CLIENT_ID=
LINGMIRROR_SSO_CLIENT_SECRET=
# 验证主站签发的 SSO 令牌只需【公钥】，且以【文件路径】引用（密钥永不写进 .env/代码/对话）。
# 私钥留在签发方（api.lingmirror.com.cn），绝不放到视频站。把公钥落到服务器：
#   sudo install -m 600 -D 主站SSO公钥.pem /opt/video/keys/lingmirror_sso_public.pem
LINGMIRROR_JWT_PUBLIC_KEY_FILE=/opt/video/keys/lingmirror_sso_public.pem
# 视频站【独立钱包 / 计费】——与主站钱包不互通，本站自有余额与账单
VIDEO_WALLET_ENABLED=false
VIDEO_WALLET_DB=/data/wallet.sqlite
# 计费模式（按秒 / 按模型 / 按 GPU 使用量 / 会员订阅）
VIDEO_BILLING_PER_SECOND=
VIDEO_BILLING_BY_MODEL=
VIDEO_BILLING_BY_GPU=
VIDEO_MEMBERSHIP_PLANS=
# 本站独立收款（充值）
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GITHUB_CLIENT_ID=
