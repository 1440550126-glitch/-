# ================= LingMirror AI 视频 · 环境变量（复制为 /opt/video/.env）=================
# 所有 API Key 仅放这里（环境变量），绝不写死在代码；留空则走本地占位引擎可先上线。

# ---- 运行（容器内，勿改；对外端口由 docker-compose 映射为 3002）----
LINGJING_PORT=4399
LINGJING_DB_PATH=/data/lingjing.sqlite
LINGJING_UPLOAD_DIR=/data/uploads

# ---- AI 模型供应商（按需填，可多家并存，自由切换）----
# 火山方舟（Seedream 文生图 / Seedance 文生·图生视频；UUID 形态 Key，非 AKLT）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OpenAI（GPT Image）
OPENAI_API_KEY=
# Google（Veo 3 文生/图生视频）
GOOGLE_API_KEY=
# 阿里云百炼 DashScope（千问对话 + 通义万相 图/视频，统一 Key）
DASHSCOPE_API_KEY=
# Vidu（全能参考·多主体一致视频）
VIDU_API_KEY=
# 火山语音 TTS（AI 配音）
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=

# ================= 以下为「预留接口」：与 LingMirror 主站账号/钱包互通（后续启用）=================
# 主站 SSO（账号互通：PayPal/Google/GitHub/邮箱登录走主站）
LINGMIRROR_SSO_URL=https://api.lingmirror.com.cn
LINGMIRROR_SSO_CLIENT_ID=
LINGMIRROR_SSO_CLIENT_SECRET=
LINGMIRROR_JWT_PUBLIC_KEY=
# 共用钱包 / 计费（按秒·按模型·按 GPU 扣费、会员订阅）
LINGMIRROR_WALLET_API=https://api.lingmirror.com.cn/wallet
LINGMIRROR_BILLING_API=https://api.lingmirror.com.cn/billing
# 第三方登录 / 支付（后续）
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GITHUB_CLIENT_ID=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
