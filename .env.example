# ===== AI句灵 服务端配置（复制为 .env 使用，所有项都有安全默认值，可以不配直接跑） =====

# 监听端口
PORT=3000

# SQLite 数据库文件位置（默认 var/jvling.sqlite；生产可迁移 PostgreSQL，见 docs/DATABASE.md）
# DB_PATH=var/jvling.sqlite

# 会话签名密钥（不配置时首次启动自动生成并持久化到数据库 settings 表）
# APP_SECRET=please-change-me

# ===== 大模型配置（全部留空 = 纯本地规则引擎，零成本可完整体验） =====
# 任何 OpenAI 兼容接口均可：火山方舟 / 阿里百炼 / 腾讯混元 / DeepSeek / OpenAI
# LLM_PROVIDER=ark            # ark | dashscope | hunyuan | openai | none
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#   ↑ 火山方舟：控制台→API Key 管理→创建（UUID 形态）。
#     注意：AKLT 开头的是火山引擎 AccessKey（OpenAPI 签名用），不能直接当 Bearer Key 用！
#     配置后运行 node scripts/llm-test.mjs 一键自检。Key 只放服务端，永远不要下发给前端
# LLM_MODEL_DEFAULT=doubao-seed-1-6-flash-250615    # 低成本默认模型
# LLM_MODEL_PREMIUM=doubao-seed-1-6-250615          # 高级额度才允许调用的模型

# 模型单价（元/千 token，用于成本统计；按你实际开通的价格改）
# LLM_PRICE_DEFAULT_IN=0.00015
# LLM_PRICE_DEFAULT_OUT=0.0015
# LLM_PRICE_PREMIUM_IN=0.0008
# LLM_PRICE_PREMIUM_OUT=0.008

# AI 暖场每日成本上限（元）。超过后当天暖场自动只用本地模板，不再调用大模型
# WARMUP_DAILY_BUDGET=2.0

# 管理员初始账号（首次启动种子化；务必上线前修改）
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=jvling-admin-2026

# ===== 远程控制 Mac（手机/电脑浏览器控制你的 Mac，详见 mac-agent/README.md） =====
# 留空 = 功能关闭（默认安全）。设置后浏览器打开 /remote.html、agent 端用同一口令即可。
# 用强随机口令：openssl rand -hex 24
# REMOTE_TOKEN=
#   ↑ 同一个口令：服务端、Mac 上的 agent、浏览器控制台三处都用它。公网部署务必走 HTTPS。
#   支持多台 Mac（各 agent 用稳定 deviceId 注册，控制台下拉切换）。
# REMOTE_MAX_FILE=524288000   # 文件传输单文件上限（字节），默认 500MB
# REMOTE_TMP_DIR=var/remote-tmp  # 文件中转临时目录（取走或 10 分钟后自动清理）
#   Mac 端（mac-agent）的开关在 agent 进程的环境变量里，详见 mac-agent/README.md：
#     REMOTE_ALLOW_POWER=1（关机/重启） REMOTE_ALLOW_SHELL=1（执行命令）
#     REMOTE_UNLOCK_PASSWORD=...（远程解锁，密码只存 Mac 本机、永不上网）
#     REMOTE_DEVICE_ID=...（自定义设备标识，默认按主机名自动生成并持久化）
