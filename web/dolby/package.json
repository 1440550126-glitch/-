{
  "name": "dolby-audio",
  "version": "1.11.0",
  "description": "独立、零依赖的杜比风格沉浸音效引擎、播放器与音频可视化（纯 Web Audio + Canvas）：低频增强 / 声场展宽 / 耳机 HRTF 虚拟环绕 / 空间混响 / 多频带压缩 / 响度对齐 / 人声增强 / 图形均衡 / 播放列表 / 锁屏控制 / A/B 盲测 / 湍流可视化。可挂在 <audio>/<video> 或任意 AudioNode 后端。",
  "type": "module",
  "main": "dolby-audio.js",
  "module": "dolby-audio.js",
  "types": "dolby-audio.d.ts",
  "exports": {
    ".": {
      "types": "./dolby-audio.d.ts",
      "default": "./dolby-audio.js"
    },
    "./store": {
      "types": "./dolby-store.d.ts",
      "default": "./dolby-store.js"
    },
    "./player": {
      "types": "./dolby-player.d.ts",
      "default": "./dolby-player.js"
    },
    "./abtest": {
      "types": "./dolby-abtest.d.ts",
      "default": "./dolby-abtest.js"
    },
    "./visualizer": {
      "types": "./dolby-visualizer.d.ts",
      "default": "./dolby-visualizer.js"
    },
    "./visualizer-gl": {
      "types": "./dolby-visualizer-gl.d.ts",
      "default": "./dolby-visualizer-gl.js"
    }
  },
  "files": [
    "dolby-audio.js",
    "dolby-audio.d.ts",
    "dolby-store.js",
    "dolby-store.d.ts",
    "dolby-player.js",
    "dolby-player.d.ts",
    "dolby-abtest.js",
    "dolby-abtest.d.ts",
    "dolby-visualizer.js",
    "dolby-visualizer.d.ts",
    "dolby-visualizer-gl.js",
    "dolby-visualizer-gl.d.ts",
    "demo.html",
    "demo.js",
    "player.html",
    "player.js",
    "README.md"
  ],
  "scripts": {
    "test": "node test/dolby.test.mjs"
  },
  "sideEffects": false,
  "keywords": [
    "web-audio",
    "audio",
    "dsp",
    "dolby",
    "immersive",
    "spatial-audio",
    "surround",
    "stereo-widener",
    "reverb",
    "bass-boost",
    "audio-effects"
  ],
  "license": "MIT"
}
