/* TA 的状态 */
.map-card { padding: 0; overflow: hidden; position: relative; }
.map { width: 100%; height: 440rpx; display: block; }
.map-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; background: var(--c-input); }
.map-empty .em { font-size: 80rpx; }
.map-dist { position: absolute; left: 24rpx; bottom: 24rpx; background: rgba(0,0,0,.55); color: #fff; font-size: 24rpx; padding: 12rpx 22rpx; border-radius: 999rpx; }

.status-row { display: flex; align-items: center; gap: 22rpx; }
.sr-line { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.sr-line:last-child { margin-bottom: 0; }
.sr-line.big { margin-bottom: 0; }
.sr-label { width: 110rpx; font-size: 26rpx; color: var(--c-text2); flex-shrink: 0; }
.sr-val { font-size: 26rpx; font-weight: 700; color: var(--c-text); }
.sr-val2 { font-size: 26rpx; color: var(--c-text); }

/* 电量条 */
.batt { width: 120rpx; height: 28rpx; border-radius: 8rpx; border: 3rpx solid var(--c-line); padding: 3rpx; position: relative; }
.batt::after { content: ''; position: absolute; right: -9rpx; top: 8rpx; width: 6rpx; height: 12rpx; border-radius: 0 4rpx 4rpx 0; background: var(--c-line); }
.batt-fill { height: 100%; border-radius: 4rpx; transition: width .4s ease; }

/* 数据格子 */
.stat-box { background: var(--c-input); border-radius: 22rpx; padding: 26rpx 16rpx; text-align: center; display: flex; flex-direction: column; gap: 8rpx; }
.sb-num { font-size: 40rpx; font-weight: 800; color: var(--c-primary2); }

/* 在线小圆点 */
.online-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #C9BFC6; flex-shrink: 0; }
.online-dot.on { background: #2FA866; box-shadow: 0 0 0 6rpx rgba(47,168,102,.18); }

/* 好久没看 · 关心提醒卡 */
.care-card { display: flex; align-items: center; gap: 20rpx; padding: 28rpx; margin-bottom: 28rpx; border-radius: 28rpx; background: linear-gradient(135deg, var(--c-soft), var(--c-card)); border: 2rpx solid var(--c-primary); box-shadow: 0 12rpx 36rpx var(--c-shadow); }
.care-emoji { font-size: 56rpx; }
.care-title { font-size: 28rpx; font-weight: 700; color: var(--c-text); }
.care-sub { font-size: 23rpx; color: var(--c-text2); }

/* 设置行（本页用） */
.set-row { display: flex; align-items: center; justify-content: space-between; }
.set-label { font-size: 28rpx; color: var(--c-text); }
.set-val { font-size: 25rpx; color: var(--c-muted); display: flex; align-items: center; gap: 10rpx; }
.set-val .arrow { color: var(--c-muted); font-size: 34rpx; }
