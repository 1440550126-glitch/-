<!-- 会员中心 -->
<view class="theme-{{theme}} page-root">
<view class="page">

  <view class="mem-hero fade-in">
    <view class="crown breathe">👑</view>
    <view class="mem-title">猫约时光 会员</view>
    <view class="sub" wx:if="{{isMember}}">你已是会员 · 当前：{{tier}}</view>
    <view class="sub" wx:else>开通会员，解锁更多专属功能</view>
  </view>

  <view class="card fade-in">
    <view class="card-title"><view class="dot"></view><text class="title">会员权益</text></view>
    <view class="perk" wx:for="{{perks}}" wx:key="t">
      <text class="perk-e">{{item.e}}</text><text class="grow">{{item.t}}</text><text class="perk-ok">✓</text>
    </view>
  </view>

  <view class="card fade-in">
    <view class="card-title"><view class="dot"></view><text class="title">选择套餐</text></view>
    <view class="plan" wx:for="{{plans}}" wx:key="key" bindtap="open" data-key="{{item.key}}">
      <view class="grow">
        <view class="plan-name">{{item.name}} <text wx:if="{{item.tag}}" class="tag">{{item.tag}}</text></view>
        <text class="sub">{{item.per}}</text>
      </view>
      <view class="plan-price"><text class="pp-sym">¥</text><text class="pp-num">{{item.price}}</text></view>
    </view>
    <view class="sub center-text mt-s">原型阶段为模拟开通，不会真实扣款</view>
  </view>

  <view wx:if="{{isMember}}" class="cancel-link center" bindtap="cancelMember">仅测试：关闭会员状态</view>

</view>
</view>
