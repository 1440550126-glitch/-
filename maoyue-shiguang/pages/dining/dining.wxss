/* 情侣点餐 */
.decider { text-align: center; padding: 44rpx 32rpx; }
.dish-emoji { font-size: 170rpx; line-height: 1.1; }
.dish-emoji.spin { animation: dishPop .12s ease-in-out infinite; }
@keyframes dishPop { 0%,100% { transform: scale(1); } 50% { transform: scale(1.12); } }
.dish-name { font-size: 44rpx; font-weight: 800; color: var(--c-text); margin-top: 12rpx; }
.result-tip { margin-top: 12rpx; color: var(--c-primary2); font-weight: 600; font-size: 28rpx; }

.note-input-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.dish-chips { display: flex; flex-wrap: wrap; gap: 16rpx; }
.dish-chip { display: inline-flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; border-radius: 999rpx; background: var(--c-soft); color: var(--c-text); font-size: 26rpx; }
.chip-x { color: var(--c-muted); font-size: 24rpx; }
