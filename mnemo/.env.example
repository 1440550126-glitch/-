# Mnemo 配置示例：复制为 .env（或写进 ~/.mnemo/.env）。任选其一即可解锁完整能力；
# 全部留空也能跑（离线兜底）。密钥优先从环境变量读取，更安全。

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- OpenAI 兼容（OpenAI / DeepSeek / Kimi / 通义百炼 / 火山方舟 / vLLM / LM Studio …）---
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# 示例 · DeepSeek：
#   OPENAI_API_KEY=sk-xxx
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat

# --- 本地 Ollama（完全离线、零成本，mnemo 会自动探测）---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --- 默认行为（可选）---
# MNEMO_PROVIDER=auto      # auto / anthropic / openai / ollama / offline
# MNEMO_MODEL=
# MNEMO_HOME=~/.mnemo
